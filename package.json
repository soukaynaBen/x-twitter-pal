{
  "name": "x-twitter-bulk-actions",
  "displayName": "X twitter bulk actions",
  "version": "0.0.1",
  "description": "Web extension for twitter-x allows users to perform a single operation on multiple items, this extension reduces repetitive tasks, and saves time.",
  "author": "soukaynaben",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.2",
    "@plasmohq/redux-persist": "^6.1.0",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "^1.3.3",
    "@reduxjs/toolkit": "^2.12.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.474.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "^9.3.0",
    "redux": "^5.0.1",
    "redux-persist-webextension-storage": "^1.0.2",
    "redux-thunk": "^3.1.0",
    "tailwind-merge": "3.0.1",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.17",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "prettier-plugin-tailwindcss": "0.6.11",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://x.com/*",
      "https://.x.com/*",
      "ws://localhost:1815/"
    ],
    "permissions": [
      "webRequest",
      "webRequestBlocking",
      "storage",
      "tabs",
      "webNavigation"
    ]
  }
}
